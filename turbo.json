{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_PRODUCT_SERVICE_URL",
        "NEXT_PUBLIC_ORDER_SERVICE_URL",
        "NEXT_PUBLIC_PAYMENT_SERVICE_URL",
        "STRIPE_SECRET_KEY",
        "MONGO_URL",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_RAZORPAY_KEY_ID",
        "NEXT_PUBLIC_BSN_API_KEY",
        "NEXT_PUBLIC_AUTH_SERVICE_URL",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_CLOUDINARY_API_KEY"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    }
  }
}